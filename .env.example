# =============================================================================
# OpenEvents Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=OpenEvents

# Default currency for the platform (ISO 4217 code)
DEFAULT_CURRENCY=EUR

# =============================================================================
# Database (PostgreSQL on OSC)
# =============================================================================
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://openevents:YOUR_PASSWORD@REDACTED_HOST:10515/openevents

# =============================================================================
# Authentication (NextAuth.js)
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
# Create credentials at: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# Create credentials at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# Object Storage (MinIO on OSC)
# =============================================================================
# MinIO/S3 endpoint URL
S3_ENDPOINT=https://REDACTED_S3_ENDPOINT
S3_PUBLIC_URL=https://REDACTED_S3_ENDPOINT

# S3 credentials (same as MinIO root user/password)
S3_ACCESS_KEY_ID=openevents
S3_SECRET_ACCESS_KEY=YOUR_MINIO_PASSWORD

# S3 bucket name for media files
S3_BUCKET_NAME=openevents-media

# S3 region (can be any value for MinIO)
S3_REGION=us-east-1

# =============================================================================
# Cache (Valkey/Redis on OSC)
# =============================================================================
# Format: redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://:YOUR_VALKEY_PASSWORD@REDACTED_HOST:10533

# =============================================================================
# Email (SMTP)
# =============================================================================
# Development: Use MailSlurper or Mailhog
# Production: Use SendGrid, Postmark, or other provider

SMTP_HOST=localhost
SMTP_PORT=2500
SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password

# From email address
EMAIL_FROM=noreply@openevents.local

# =============================================================================
# Payments (PayPal - Stub for now)
# =============================================================================
# Set to 'true' to use PayPal sandbox, 'false' for production
PAYPAL_SANDBOX=true

# PayPal API credentials (not needed until live integration)
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# =============================================================================
# OSC (Eyevinn Open Source Cloud)
# =============================================================================
# Access token for OSC API
OSC_ACCESS_TOKEN=your-osc-access-token

# =============================================================================
# Development
# =============================================================================
# Enable verbose logging in development
# DEBUG=prisma:query

# =============================================================================
# Production Notes
# =============================================================================
# For production deployment on OSC:
# 1. Set NODE_ENV=production
# 2. Update NEXT_PUBLIC_APP_URL to your production URL
# 3. Use strong passwords for all services
# 4. Configure a real transactional email provider
# 5. Set up PayPal production credentials
